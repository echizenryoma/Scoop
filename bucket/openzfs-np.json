{
    "version": "2.4.1rc9-8",
    "description": "The open source port of OpenZFS on Windows",
    "homepage": "https://openzfsonwindows.org",
    "license": "Freeware",
    "url": "https://github.com/openzfsonwindows/openzfs/releases/download/zfswin-2.4.1rc9/OpenZFSOnWindows-debug-2.4.1rc9-8.exe#/setup.exe",
    "hash": "700bbdd5fde6395937276b0edb8c260065062fadc939a786b099124454315d5a",
    "installer": {
        "args": [
            "/VERYSILENT",
            "/NOCANCEL",
            "/NORESTART",
            "/CLOSEAPPLICATIONS"
        ]
    },
    "checkver": {
        "script": [
            "$resp = Invoke-WebRequest -Uri 'https://api.github.com/repos/openzfsonwindows/openzfs/releases/latest'",
            "$json = $resp.Content | ConvertFrom-Json",
            "$tag = $json.tag_name -replace 'zfswin-',''",
            "$version = $json.assets[-1].name -replace 'OpenZFSOnWindows-debug-','' -replace '.exe',''",
            "Write-Output \"$version $tag\""
        ],
        "regex": "(?<version>.+)\\s(?<tag>.+)"
    },
    "autoupdate": {
        "url": "https://github.com/openzfsonwindows/openzfs/releases/download/zfswin-$matchTag/OpenZFSOnWindows-debug-$version.exe#/setup.exe"
    }
}
