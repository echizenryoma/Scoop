{
    "version": "2.4.1rc7",
    "description": "The open source port of OpenZFS on Windows",
    "homepage": "https://openzfsonwindows.org",
    "license": "Freeware",
    "url": "https://github.com/openzfsonwindows/openzfs/releases/download/zfswin-2.4.1rc7/OpenZFSOnWindows-debug-2.4.1rc7.exe#/setup.exe",
    "hash": "9392dd310693502d0a13ea6ef130bcf79732db0ed30733d0cd90c8b3117c98d4",
    "installer": {
        "args": [
            "/VERYSILENT",
            "/NOCANCEL",
            "/NORESTART",
            "/CLOSEAPPLICATIONS"
        ]
    },
    "checkver": {
        "script": [
            "$resp = Invoke-WebRequest -Uri 'https://api.github.com/repos/openzfsonwindows/openzfs/releases/latest'",
            "$json = $resp.Content | ConvertFrom-Json",
            "$json.tag_name -replace 'zfswin-',''"
        ],
        "regex": "(?<version>.+)"
    },
    "autoupdate": {
        "url": "https://github.com/openzfsonwindows/openzfs/releases/download/zfswin-$version/OpenZFSOnWindows-debug-$version.exe#/setup.exe"
    }
}
