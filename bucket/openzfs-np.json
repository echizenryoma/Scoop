{
    "version": "2.4.1rc13d",
    "description": "The open source port of OpenZFS on Windows",
    "homepage": "https://github.com/openzfsonwindows/openzfs",
    "license": "Freeware",
    "url": "https://github.com/openzfsonwindows/openzfs/releases/download/zfswin-2.4.1rc12/OpenZFSOnWindows-debug-2.4.1rc13d.exe#/setup.exe",
    "hash": "be45d03a116acdc119a1ca50e12951477ad3bd31d72cfe60b3b26d2618d13681",
    "installer": {
        "args": [
            "/VERYSILENT",
            "/NOCANCEL",
            "/NORESTART",
            "/CLOSEAPPLICATIONS"
        ]
    },
    "checkver": {
        "script": [
            "$resp = Invoke-WebRequest -Uri 'https://api.github.com/repos/openzfsonwindows/openzfs/releases/latest'",
            "$json = $resp.Content | ConvertFrom-Json",
            "$tag = $json.tag_name -replace 'zfswin-',''",
            "$version = ($json.assets | Sort-Object updated_at)[-1].name -replace 'OpenZFSOnWindows-debug-','' -replace '.exe',''",
            "Write-Output \"$version $tag\""
        ],
        "regex": "(?<version>.+)\\s(?<tag>.+)"
    },
    "autoupdate": {
        "url": "https://github.com/openzfsonwindows/openzfs/releases/download/zfswin-$matchTag/OpenZFSOnWindows-debug-$version.exe#/setup.exe"
    }
}
